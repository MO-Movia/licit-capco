{
  "name": "@modusoperandi/licit-capco",
  "version": "1.1.0",
  "type": "module",
  "description": "MO's Capco ProseMirror Plugin",
  "main": "index.js",
  "types": "index.d.ts",
  "style": "style/styles.css",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MO-Movia/licit-capco"
  },
  "scripts": {
    "build": "tsc --build && copyfiles --up 1 \"src/**/*.css\" dist  && copyfiles package.json dist",
    "test": "jest --coverage",
    "clean": "rm -rf dist/ && rm -f mo-licit-capco-*.*.*.tgz",
    "lint:ts": "eslint src --ext .ts,.tsx --fix",
    "lint": "npm run lint:ts",
    "test:unit": "jest --coverage",
    "test:coverage": "jest --coverage",
    "publish:capco": "npm publish",
    "update": "npx npm-check-updates --peer --target semver -u && npm update && npm i",
    "ci:bom": "npx cyclonedx-npm --ignore-npm-errors --short-PURLs --output-format XML --output-file dist/bom.xml",
    "ci:build": "tsc -b tsconfig.prod.json --clean && tsc -b tsconfig.prod.json && copyfiles --up 1 \"src/**/*.css\" dist  && copyfiles package.json README.md LICENSE dist",
    "verify": "npm run lint -- --fix && npm run ci:build && npm run test:coverage && echo 'All Tests Passed!'"
  },
  "peerDependencies": {
    "@modusoperandi/licit-ui-commands": "^1.0.0",
    "@modusoperandi/licit-doc-attrs-step": "^1.0.5",
    "prosemirror-utils": "^1.2.2",
    "prosemirror-state": "^1.4.3",
    "prosemirror-model": "^1.25.3",
    "prosemirror-view": "^1.41.3",
    "react": "^18.0.0",
    "react-select": "^5.8.0"
  },
  "dependencies": {
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^18.3.7",
    "@modusoperandi/eslint-config": "^3.0.3",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^14.0.1",
    "jest-prosemirror": "^3.0.1",
    "jest-sonar-reporter": "^2.0.0",
    "prettier": "^3.7.4",
    "prosemirror-test-builder": "^1.1.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
